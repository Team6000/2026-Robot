
import math
import commands2
from subsystems import shooter, hopper
from commands.fancy_driving.manual_aimtodirection import AimToDirection


class IntakeCommand(commands2.Command):
    def __init__(self, drivetrain):
        super().__init__()

        self.shooter = shooter.Shooter()
        self.hopper = hopper.Hopper()


    def intake(self):
        self.shooter.intakeRun()
        self.hopper.hopper_motor_spin_inwards()

    def execute(self):
        self.intake()
